# Environment variables template
# Copy this to .env and update with your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_RELOAD=False

# Model Configuration
MODEL_PATH=./model/model.pkl
SCALER_PATH=./model/scaler.pkl

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Docker Hub Configuration (for Jenkins)
DOCKER_HUB_USERNAME=your_username
DOCKER_HUB_PASSWORD=your_password
DOCKER_HUB_REPO=your_username/ml-api

# Database (if needed)
DATABASE_URL=sqlite:///./test.db

# Feature Flags
ENABLE_CACHING=True
ENABLE_PROFILING=False
